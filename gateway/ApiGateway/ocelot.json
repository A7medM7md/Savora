          "Url": "https://localhost:7169/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "notifications",
      "Config": [
        {
          "Name": "Notifications Service",
          "Version": "v1",
          "Url": "https://localhost:7278/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "expenses",
      "Config": [
        {
          "Name": "Expense Service",
          "Version": "v1",
          "Url": "https://localhost:7084/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7119"
  }
}